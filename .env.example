# Supabase — Settings → API in your Supabase dashboard
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
REACT_APP_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Anthropic — proxy key for Claude Vision
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# OpenPhone (Quo) — API key from openphone.com
OPENPHONE_API_KEY=YOUR_OPENPHONE_KEY_HERE
# Phone number ID — found in your PM project's Vercel env as QUO_PHONE_ID
OPENPHONE_PHONE_ID=YOUR_PHONE_NUMBER_ID_HERE

# Your number to receive SMS notifications
NOTIFY_PHONE=3854062408
